{
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://rootchain-v2-production.up.railway.app/api/v1/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
