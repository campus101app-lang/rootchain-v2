{
  "name": "rootchain-v2",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/admin",
    "apps/landing",
    "server",
    "packages/shared"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=@rootchain/web",
    "dev:admin": "npm run dev --workspace=@rootchain/admin",
    "dev:landing": "npm run dev --workspace=landing",
    "dev": "npm run dev:api & npm run dev:web",
    "db:deploy": "npm run db:deploy --workspace=server",
    "db:seed": "npm run db:seed --workspace=server"
  }
}
